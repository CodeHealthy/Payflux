# PayFlux local environment template.
# Copy this file to .env for local overrides. Do not commit real production secrets.

# Shared backend config
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=payflux-authservice
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JPA_SHOW_SQL=true
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# Service ports
AUTHSERVICE_PORT=8080
ACCOUNTSERVICE_PORT=8081
NOTIFICATIONSERVICE_PORT=8082
WALLETSERVICE_PORT=8083
BENEFICIARYSERVICE_PORT=8084
TRANSACTIONSERVICE_PORT=8086
AUDITSERVICE_PORT=8087
GATEWAYSERVICE_PORT=8088

# Gateway/service URLs
AUTHSERVICE_BASE_URL=http://localhost:8080
ACCOUNTSERVICE_BASE_URL=http://localhost:8081
NOTIFICATIONSERVICE_BASE_URL=http://localhost:8082
WALLETSERVICE_BASE_URL=http://localhost:8083
BENEFICIARYSERVICE_BASE_URL=http://localhost:8084
TRANSACTIONSERVICE_BASE_URL=http://localhost:8086
AUDITSERVICE_BASE_URL=http://localhost:8087

# Kafka
KAFKA_IMAGE=apache/kafka:4.0.0
KAFKA_CONTAINER_NAME=payflux-kafka
KAFKA_HOST_PORT=9092
KAFKA_ADVERTISED_LISTENERS=INTERNAL://kafka:29092,EXTERNAL://localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_TOPIC_ACCOUNT_CREATED=account-created
KAFKA_TOPIC_USER_REGISTERED=user-registered
KAFKA_TOPIC_TRANSFER_COMPLETED=transfer-completed
KAFKA_TOPIC_BENEFICIARY_ADDED=beneficiary-added
KAFKA_TOPIC_ADMIN_WALLET_STATUS_CHANGED=admin-wallet-status-changed
KAFKA_TOPIC_TRANSFER_OTP_REQUESTED=transfer-otp-requested
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:v0.7.2
KAFKA_UI_CONTAINER_NAME=payflux-kafka-ui
KAFKA_UI_HOST_PORT=8085

# Redis
REDIS_IMAGE=redis:7.4-alpine
REDIS_CONTAINER_NAME=payflux-redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_PASSWORD=

# PostgreSQL Docker image
POSTGRES_IMAGE=postgres:16

# Account database
ACCOUNT_DB_CONTAINER_NAME=payflux-account-db
ACCOUNT_DB_HOST_PORT=5543
ACCOUNT_DB_NAME=accountdb
ACCOUNT_DB_USER=payflux
ACCOUNT_DB_PASSWORD=accountAdmin
ACCOUNTSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5543/accountdb
ACCOUNTSERVICE_DATASOURCE_USERNAME=payflux
ACCOUNTSERVICE_DATASOURCE_PASSWORD=accountAdmin

# Notification database
NOTIFICATION_DB_CONTAINER_NAME=payflux-notification-db
NOTIFICATION_DB_HOST_PORT=5544
NOTIFICATION_DB_NAME=notificationdb
NOTIFICATION_DB_USER=payflux
NOTIFICATION_DB_PASSWORD=notificationAdmin
NOTIFICATIONSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5544/notificationdb
NOTIFICATIONSERVICE_DATASOURCE_USERNAME=payflux
NOTIFICATIONSERVICE_DATASOURCE_PASSWORD=notificationAdmin

# Wallet database
WALLET_DB_CONTAINER_NAME=payflux-wallet-db
WALLET_DB_HOST_PORT=5545
WALLET_DB_NAME=walletdb
WALLET_DB_USER=payflux
WALLET_DB_PASSWORD=walletAdmin
WALLETSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5545/walletdb
WALLETSERVICE_DATASOURCE_USERNAME=payflux
WALLETSERVICE_DATASOURCE_PASSWORD=walletAdmin

# Auth database
AUTH_DB_CONTAINER_NAME=payflux-auth-db
AUTH_DB_HOST_PORT=5546
AUTH_DB_NAME=authdb
AUTH_DB_USER=payflux
AUTH_DB_PASSWORD=authAdmin
AUTHSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5546/authdb
AUTHSERVICE_DATASOURCE_USERNAME=payflux
AUTHSERVICE_DATASOURCE_PASSWORD=authAdmin

# Beneficiary database
BENEFICIARY_DB_CONTAINER_NAME=payflux-beneficiary-db
BENEFICIARY_DB_HOST_PORT=5547
BENEFICIARY_DB_NAME=beneficiarydb
BENEFICIARY_DB_USER=payflux
BENEFICIARY_DB_PASSWORD=beneficiaryAdmin
BENEFICIARYSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5547/beneficiarydb
BENEFICIARYSERVICE_DATASOURCE_USERNAME=payflux
BENEFICIARYSERVICE_DATASOURCE_PASSWORD=beneficiaryAdmin

# Transaction database
TRANSACTION_DB_CONTAINER_NAME=payflux-transaction-db
TRANSACTION_DB_HOST_PORT=5548
TRANSACTION_DB_NAME=transactiondb
TRANSACTION_DB_USER=payflux
TRANSACTION_DB_PASSWORD=transactionAdmin
TRANSACTIONSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5548/transactiondb
TRANSACTIONSERVICE_DATASOURCE_USERNAME=payflux
TRANSACTIONSERVICE_DATASOURCE_PASSWORD=transactionAdmin

# Audit database
AUDIT_DB_CONTAINER_NAME=payflux-audit-db
AUDIT_DB_HOST_PORT=5549
AUDIT_DB_NAME=auditdb
AUDIT_DB_USER=payflux
AUDIT_DB_PASSWORD=auditAdmin
AUDITSERVICE_DATASOURCE_URL=jdbc:postgresql://localhost:5549/auditdb
AUDITSERVICE_DATASOURCE_USERNAME=payflux
AUDITSERVICE_DATASOURCE_PASSWORD=auditAdmin

# Auth login protection
AUTH_LOGIN_MAX_EMAIL_ATTEMPTS=5
AUTH_LOGIN_MAX_IP_ATTEMPTS=20
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=900

# Wallet transfer controls
WALLET_OUTBOX_PUBLISH_DELAY_MS=3000
TRANSFER_CONFIRMATION_TTL_SECONDS=300
TRANSFER_MAX_OTP_ATTEMPTS=3
TRANSFER_IDEMPOTENCY_TTL_SECONDS=86400
TRANSFER_RATE_LIMIT_MAX_CONFIRMATIONS=5
TRANSFER_RATE_LIMIT_WINDOW_SECONDS=60
TRANSFER_OTP_RESEND_COOLDOWN_SECONDS=30
TRANSFER_OTP_RESEND_WINDOW_SECONDS=900
TRANSFER_OTP_RESEND_MAX_RESENDS=3

# Email delivery
APP_EMAIL_PROVIDER=none
APP_EMAIL_ENABLED=true
APP_EMAIL_FROM=no-reply@payflux.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
MAIL_SMTP_TIMEOUT_MS=5000
MAIL_SMTP_WRITE_TIMEOUT_MS=5000

# Frontend/Vite
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_HOST=127.0.0.1
VITE_API_PROXY_TARGET=http://localhost:8088
VITE_API_BASE_PATH=/api
